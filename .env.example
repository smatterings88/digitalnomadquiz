# GoHighLevel Private Integration (Settings → Integrations → Private Integrations)
GHL_API_TOKEN=
GHL_LOCATION_ID=your_sub_account_location_id
GHL_API_VERSION=2021-07-28

# API server
PORT=3001

# Optional: GHL custom field IDs (Settings → Custom Fields)
# Map quiz payload keys to your GHL field IDs
GHL_FIELD_ARCHETYPE=
GHL_FIELD_CONTACT_ARCHETYPE=
GHL_FIELD_QUIZ_RESULT_CODE=
GHL_FIELD_QUIZ_SCORE_JSON=
GHL_FIELD_URGENCY=
GHL_FIELD_URGENCY_SCORE=
GHL_FIELD_SCORE_HH=
GHL_FIELD_SCORE_WL=
GHL_FIELD_SCORE_TC=
GHL_FIELD_SCORE_AR=
GHL_FIELD_SCORE_CK=
GHL_FIELD_QUIZ_COMPLETED=
GHL_FIELD_SOURCE=
